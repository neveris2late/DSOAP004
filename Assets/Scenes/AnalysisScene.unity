  m_text: "<color=#FFD700><link=\"ricky_taylor\">\u91CC\u5947\xB7\u6CF0\u52D2</link></color>\u7684\u8C03\u67E5\u6863\u6848\n\u5728<color=#FFD700><link=\"loc_rainwater\">\u5DDD\u6D41\u57CE\u96E8\u6C34\u533A</link></color>\u62E5\u6709\u56DB\u5BB6\u5496\u5561\u9152\u9986\uFF0C\u524D\u5E74\u66FE\u7ECF\u4E3A<color=#FFD700><link=\"org_model_co\">\u7EEF\u7EA2\u4E0E\u6E58\u84DD\u6A21\u7279\u516C\u53F8</link></color>\u62C5\u4EFB\u5F62\u8C61\u6539\u9020\u673A\u68B0\u5E08\uFF0C\u4E3A\u8BB8\u591A\u5E74\u8F7B\u827A\u4EBA<color=#FFD700><link=\"clue_prosthetic\">\u5B9A\u5236\u4E49\u4F53\u6539\u88C5\u8BA1\u5212</link></color>\uFF0C\u4ED6\u7684\u8C6A\u5B85\u4F4D\u4E8E\u96E8\u6C34\u533A\u7684\u5C0F\u89D2\u5C71\u4E0A\uFF0C\u5728\u53BB\u5E74\u8D2D\u5165\uFF0C\u7531\u4E24\u680B\u522B\u5885\u76F8\u8FDE\u800C\u6210\uFF0C\u636E\u53EF\u9760\u7EBF\u7D22\u5224\u65AD\uFF0C\u4ED6\u6A2A\u8DE8\u9ED1\u767D\u4E24\u754C\uFF0C\u4E0E\u8BB8\u591A<color=#FFD700><link=\"org_underground\">\u5730\u4E0B\u7EC4\u7EC7</link></color>\u6709\u6DF1\u5EA6\u7684\u8054\u7CFB\u3002\u5176\u5E74\u9F8453\u5C81\uFF0C\u4F30\u8BA1\u914D\u7F6E\u6709\u76F8\u5F53\u6570\u91CF\u7684<color=#FFD700><link=\"clue_logic_chip\">\u9AD8\u9636\u903B\u8F91\u4E0E\u63A8\u7406\u82AF\u7247</link></color>\u3002\u6211\u4EEC\u7684\u8C03\u67E5\u5458\u4E0E\u66FE\u7ECF\u4E0E\u4ED6\u6709\u8FC7\u540C\u5C45\u7ECF\u5386\u7684<color=#FFD700><link=\"npc_chen\">\u9648\u9510\u6E05</link></color>\u53D6\u5F97\u4E86\u8054\u7CFB\uFF0C\u5979\u8BA4\u4E3A\u91CC\u5947\u7684\u7CBE\u529B\u8D85\u51FA\u540C\u9F84\u4EBA\u8BB8\u591A\uFF0C\u53CD\u5E94\u901F\u5EA6\u4E5F\u5947\u4F73\uFF0C\u540C\u65F6\u884C\u8E2A\u795E\u79D8\uFF0C\u7ECF\u5E38\u7A81\u5140\u5730\u79BB\u5F00\u3002\u66FE\u7ECF\u53D7\u96C7\u4E8E\u4ED6\u7684<color=#FFD700><link=\"npc_terris\">\u6CF0\u745E\u65AF\xB7\u5B89\u5FB7\u5170</link></color>\u5DF2\u7ECF\u88AB\u67E5\u660E\u4E3A\u662F\u5730\u4E0B\u7EC4\u7EC7\u7684\u8054\u7EDC\u5458\uFF0C\u4F46\u4ED6\u5E76\u672A\u4F9B\u8FF0\u6CF0\u52D2\u6709\u53C2\u4E0E\u76F8\u5173\u7684\u6D3B\u52A8\u3002\u6211\u4EEC\u7684\u8C03\u67E5\u5458\u5BF9\u4ED6\u7684\u8FC7\u5F80\u8FDB\u884C\u6863\u6848\u8C03\u67E5\u540E\u53D1\u73B0\uFF0C\u5176\u8FC7\u53BB\u53EF\u67E5\u51FA\u7684\u7ECF\u5386\u6709\u5F88\u591A<color=#FFD700><link=\"clue_deleted_past\">\u523B\u610F\u7684\u6A21\u7CCA\u4E0E\u5220\u51CF</link></color>\uFF0C\u6839\u636E\u8C03\u67E5\u7ED3\u679C\uFF0C\u7533\u8BF7\u5BF9\u4ED6\u8FDB\u884C\u4EBA\u683C\u6D4B\u8BD5\uFF0C\u673A\u52A8\u68C0\u5BDF\u5B98\u5DF2\u6279\u51C6\u3002"
